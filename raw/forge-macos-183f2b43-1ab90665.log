1a8f970f [roha] 	const system=[];
1a8f970f [roha] 	const others=[];
1a8f970f [roha] 	for(const item of history){
1a8f970f [roha] 		if(item.role=="system") system.push(item); else others.push(item);
1a8f970f [roha] 	}
1a8f970f [roha] 	for(const list of [[...system],[...others]]){
