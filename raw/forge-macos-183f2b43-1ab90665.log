1a8f970e [roha] function mutName(modelname:string):string{
1a8f970e [roha] 	const modelAccount=modelname.split("@");
1a8f970e [roha] 	const path=modelAccount[0];
1a8f970e [roha] 	const names=path.split("/");
1a8f970e [roha] 	let name:string=names.pop()||"";
