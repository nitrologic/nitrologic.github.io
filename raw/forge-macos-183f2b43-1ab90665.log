1a8f970e [roha] function latinString(latin, line: string, space=ThinSpace): string {
1a8f970e [roha] 	const upper=Array.from(latin.upper);
1a8f970e [roha] 	const digits=Array.from(latin.digits);
1a8f970e [roha] 	const lower=latin.lower?Array.from(latin.lower):upper;
1a8f970e [roha] 	let out="";
1a8f970e [roha] 	for (const ch of line) {
1a8f970e [roha] 		const c = ch.charCodeAt(0);
1a8f970e [roha] 		if (c >= 48 && c <= 57) out += digits[c-48];
1a8f970e [roha] 		else if (c >= 65 && c <= 90) out += upper[c-65]+space;
1a8f970e [roha] 		else if (c >= 97 && c <= 122) out += lower[c-97]+space;
1a8f970e [roha] 		else out += ch;
1a8f970e [roha] 	}
1a8f970e [roha] 	return out;
1a8f970e [roha] }
