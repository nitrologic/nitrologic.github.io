1a8f970f [roha] 			encodedText = utf16le;
1a8f970f [roha] 			break;
1a8f970f [roha] //			const utf16le = new Uint8Array(encoder.encode(text).buffer,0,text.length * 2);
1a8f970f [roha] //			encodedText = new Uint8Array([0xFF, 0xFE, ...utf16le]);
1a8f970f [roha] 		case "linux":
1a8f970f [roha] 			clipCmd = "xclip";
1a8f970f [roha] 			args = ["-selection", "clipboard"];
1a8f970f [roha] 			encodedText = new TextEncoder().encode(text); // UTF-8 for Linux
1a8f970f [roha] 			break;
1a8f970f [roha] 		default:
