1a6bd5da [simon@midnightblue] for digital tv to recognise sync i may need to modify vsync from single period
1a6be1ce [kimi-k2.5] #Digital TVs often require the standard vsync pulse sequence (pre-equalizing, broad pulses,
1a6be1cf [kimi-k2.5] #post-equalizing) rather than a simple long blanking period. They detect vsync by looking for the
1a6be1cf [kimi-k2.5] #27.3µs broad pulses at half-line frequency, not just a missing signal.
1a6be1cf [kimi-k2.5] #
1a6be1cf [kimi-k2.5] #• PAL vsync structure (lines):*
1a6be1cf [kimi-k2.5] #1. 5 lines: Pre-equalizing (2.35µs low / 29.65µs high, twice per line)
1a6be1cf [kimi-k2.5] #2. 5 lines: Vertical sync (27.3µs low / 4.7µs high, twice per line)
1a6be1cf [kimi-k2.5] #3. 5 lines: Post-equalizing (same as pre-equalizing)
1a6be1cf [kimi-k2.5] #
1a6be1cf [kimi-k2.5] #• Cycle counts at 150MHz:*
1a6be1cf [kimi-k2.5] #- 2.35µs = 353 cycles
1a6be1cf [kimi-k2.5] #- 4.7µs = 705 cycles
1a6be1cf [kimi-k2.5] #- 27.3µs = 4095 cycles
1a6be1cf [kimi-k2.5] #- 29.65µs = 4448 cycles
1a6be1cf [kimi-k2.5] #- Half-line = 4800 cycles
1a6be1cf [kimi-k2.5] #
1a6be1cf [kimi-k2.5] #• PIO approach:*
1a6be1cf [kimi-k2.5] #Replace your `vblank` section with nested loops using the `in` trick to load large constants.
1a6be1cf [kimi-k2.5] #Example for broad pulses (simplified):
1a6be1cf [kimi-k2.5] #
1a6be1cf [kimi-k2.5] #
1a6be1cf [kimi-k2.5] #; Broad pulse line (27.3µs low, 4.7µs high, repeated)
1a6be1d0 [kimi-k2.5] #set y, 4					; 5 lines
1a6be1d0 [kimi-k2.5] #broad_line:
1a6be1d0 [kimi-k2.5] #	; First half: 4095 cycles low
1a6be1d0 [kimi-k2.5] #	set x, 127
1a6be1d0 [kimi-k2.5] #	in x, 5					; 127 << 5 = 3968
1a6be1d0 [kimi-k2.5] #	mov x, isr
1a6be1d0 [kimi-k2.5] #	set pins, 0				; sync low
1a6be1d0 [kimi-k2.5] #broad_low_1:
1a6be1d0 [kimi-k2.5] #	jmp x--, broad_low_1	; 3968 cycles
1a6be1d0 [kimi-k2.5] #	nop [126]				; +127 = 4095
1a6be1d0 [kimi-k2.5] #
1a6be1d0 [kimi-k2.5] #	set pins, 1				; high (black)
1a6be1d0 [kimi-k2.5] #	set x, 22
1a6be1d0 [kimi-k2.5] #	in x, 5					; 22 << 5 = 704
1a6be1d0 [kimi-k2.5] #	mov x, isr
1a6be1d0 [kimi-k2.5] #broad_high_1:
1a6be1d0 [kimi-k2.5] #	jmp x--, broad_high_1	; 704 cycles
1a6be1d0 [kimi-k2.5] #	nop [0]					; +1 = 705
1a6be1d0 [kimi-k2.5] #
1a6be1d0 [kimi-k2.5] #	; Second half (repeat low/high sequence for 64µs total)
1a6be1d0 [kimi-k2.5] #	set x, 127
1a6be1d1 [kimi-k2.5] #	in x, 5
1a6be1d1 [kimi-k2.5] #	mov x, isr
1a6be1d1 [kimi-k2.5] #	set pins, 0
1a6be1d1 [kimi-k2.5] #broad_low_2:
1a6be1d1 [kimi-k2.5] #	jmp x--, broad_low_2
1a6be1d1 [kimi-k2.5] #	nop [126]
1a6be1d1 [kimi-k2.5] #
1a6be1d1 [kimi-k2.5] #	set pins, 1
1a6be1d1 [kimi-k2.5] #	set x, 22
1a6be1d1 [kimi-k2.5] #	in x, 5
1a6be1d1 [kimi-k2.5] #	mov x, isr
1a6be1d1 [kimi-k2.5] #broad_high_2:
1a6be1d1 [kimi-k2.5] #	jmp x--, broad_high_2
1a6be1d1 [kimi-k2.5] #	nop [0]
1a6be1d1 [kimi-k2.5] #
1a6be1d1 [kimi-k2.5] #	jmp y--, broad_line
1a6be1d1 [kimi-k2.5] #
1a6be1d1 [kimi-k2.5] #
1a6be1d1 [kimi-k2.5] #If instruction space is tight (you have ~12 instructions left in your current 32-instruction
1a6be1d1 [kimi-k2.5] #program), you can often get away with just the 5 broad pulse lines and skip pre/post
1a6be1d1 [kimi-k2.5] #equalizing—many digital TVs will lock with just the broad pulse train. Generate 5 lines of (4095
1a6be1d1 [kimi-k2.5] #cycles low / 705 cycles high) repeated twice per line.
1a6be1d2 [kimi-k2.5] #
1a6be1d2 [kimi-k2.5] #Alternatively, use the CPU to trigger a DMA transfer of pre-calculated sync patterns into the PIO
1a6be1d2 [kimi-k2.5] #FIFO during blanking, keeping the PIO program simple.
1a6be1d2 [kimi-k2.5] #
