1a8f970f [roha] 			const w=2+(row[i].length|0);
1a8f970f [roha] 			if(w>(widths[i]|0)) widths[i]=w;
1a8f970f [roha] 		}
1a8f970f [roha] 	}
1a8f970f [roha] //	console.log("widths",widths);
1a8f970f [roha] 	if(addFence) result.push("```");
1a8f970f [roha] 	let header=true;
