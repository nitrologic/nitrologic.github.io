1a8f970e [roha] 								});
1a8f970e [roha] 							}
1a8f970e [roha] 							const textContent = reply.content
1a8f970e [roha] 								.filter(content => content.type === 'text')
1a8f970e [roha] 								.map(content => content.text)
1a8f970e [roha] 								.join('\n'); // Combine multiple text blocks if any
