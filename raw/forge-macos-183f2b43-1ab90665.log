1a8fb4a8 [gemini-3.1-pro] #The Google API implementation is on the right track, mapping OpenAI-style payloads to Gemini's
1a8fb4a8 [gemini-3.1-pro] #structure. However, there are two key issues in `prepareGeminiPrompt` and one potential crash in
1a8fb4a9 [gemini-3.1-pro] #`connectGoogle` related to your recent tool calling and continuity fixes.
1a8fb4a9 [gemini-3.1-pro] #
1a8fb4a9 [gemini-3.1-pro] #1. Continuity Issue in `prepareGeminiPrompt`
1a8fb4a9 [gemini-3.1-pro] #In your `assistant` case, you are checking for `item.toolcallid` instead of
1a8fb4a9 [gemini-3.1-pro] #`item.toolcalls`. When the assistant makes a tool call, OpenAI format uses `toolcalls`.
1a8fb4a9 [gemini-3.1-pro] #Because of this typo, the code falls through to the `else` block and pushes an empty text part
1a8fb4a9 [gemini-3.1-pro] #instead of the required `functionCall` object, breaking Gemini's conversation history.
1a8fb4a9 [gemini-3.1-pro] #
1a8fb4a9 [gemini-3.1-pro] #Additionally, in the `tool` case, Gemini expects the role to be `"function"`, not `"tool"`.
1a8fb4a9 [gemini-3.1-pro] #
1a8fb4a9 [gemini-3.1-pro] #Here is the corrected switch block for `prepareGeminiPrompt`:
1a8fb4a9 [gemini-3.1-pro] #
1a8fb4a9 [gemini-3.1-pro] #
1a8fb4a9 [gemini-3.1-pro] #			case "assistant": {
1a8fb4a9 [gemini-3.1-pro] #				if (item.tool_calls) {
1a8fb4a9 [gemini-3.1-pro] #					const parts = item.tool_calls.map(tc => ({
1a8fb4a9 [gemini-3.1-pro] #						functionCall: {
1a8fb4a9 [gemini-3.1-pro] #							name: tc.function.name,
1a8fb4a9 [gemini-3.1-pro] #							args: JSON.parse(tc.function.arguments)
1a8fb4a9 [gemini-3.1-pro] #						}
1a8fb4a9 [gemini-3.1-pro] #					}));
1a8fb4aa [gemini-3.1-pro] #					contents.push({ role: "model", parts });
1a8fb4aa [gemini-3.1-pro] #				} else {
1a8fb4aa [gemini-3.1-pro] #					contents.push({ role: "model", parts: [{ text: item.content || "" }] });
1a8fb4aa [gemini-3.1-pro] #				}
1a8fb4aa [gemini-3.1-pro] #				break;
1a8fb4aa [gemini-3.1-pro] #			}
1a8fb4aa [gemini-3.1-pro] #			case "tool": {
1a8fb4aa [gemini-3.1-pro] #				const functionResponse = { name: item.name, response: JSON.parse(text) };
1a8fb4aa [gemini-3.1-pro] #				if (debugging) echo("[GEMINI] functionResponse", functionResponse);
1a8fb4aa [gemini-3.1-pro] #				contents.push({ role: "function", parts: [{ functionResponse }] });
1a8fb4aa [gemini-3.1-pro] #				break;
1a8fb4aa [gemini-3.1-pro] #			}
1a8fb4aa [gemini-3.1-pro] #
1a8fb4aa [gemini-3.1-pro] #
1a8fb4aa [gemini-3.1-pro] #2. Potential Crash in `connectGoogle`
1a8fb4aa [gemini-3.1-pro] #When Gemini decides to call a function, it often omits text entirely. Calling `await
1a8fb4aa [gemini-3.1-pro] #result.response.text()` will throw an error if no text parts exist in the response, terminating the
1a8fb4ab [gemini-3.1-pro] #relay.
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #You should wrap the text extraction in a try-catch block:
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #						let text = "";
1a8fb4ab [gemini-3.1-pro] #						try {
1a8fb4ab [gemini-3.1-pro] #							text = await result.response.text();
1a8fb4ab [gemini-3.1-pro] #						} catch (e) {
1a8fb4ab [gemini-3.1-pro] #							// Ignored: model returned a pure tool call without text
1a8fb4ab [gemini-3.1-pro] #						}
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #						const usage = result.response.usageMetadata || {};
1a8fb4ab [gemini-3.1-pro] #						const choices = [];
1a8fb4ab [gemini-3.1-pro] #						choices.push({ message: { content: text || null } });
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #						const calls = result.response.functionCalls();
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #
1a8fb4ab [gemini-3.1-pro] #With these adjustments, the model's tool calls will be properly formatted as `functionCall` objects
1a8fb4ab [gemini-3.1-pro] #in the history, the tool results will be returned as `functionResponse` parts, and the strict
1a8fb4ab [gemini-3.1-pro] #alternating continuity required by the Gemini API will be maintained.
1a8fb4ab [gemini-3.1-pro] #
