1a8f970f [roha] 	}
1a8f970f [roha] 	try {
1a8f970f [roha] 		const process = Deno.run({cmd: [clipCmd, ...args],stdin: "piped",stdout: "piped",stderr: "piped",});
1a8f970f [roha] 		await process.stdin.write(encodedText);
1a8f970f [roha] 		process.stdin.close();
1a8f970f [roha] 		const status = await process.status();
1a8f970f [roha] 		if (!status.success) {
