1a8f970f [roha] 			// Convert UTF-8 to UTF-16LE
1a8f970f [roha] 			let offset = 2;
1a8f970f [roha] 			for (let i = 0; i < text.length; i++) {
1a8f970f [roha] 				const charCode = text.charCodeAt(i);
1a8f970f [roha] 				utf16le[offset++] = charCode & 0xFF;
