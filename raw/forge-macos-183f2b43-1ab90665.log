1a8f970d [roha] function ansiStyle(text:string, style:string="bold", colorIndex:number=-1) {
1a8f970d [roha] 	if (!roha.config.ansi) return text;
1a8f970d [roha] 	let formatted=text;
1a8f970d [roha] 	switch (style.toLowerCase()) {
