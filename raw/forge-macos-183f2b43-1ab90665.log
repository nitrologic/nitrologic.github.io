1a8f970f [roha] 		if(header){
1a8f970f [roha] 			result.push(boxTop(widths));
1a8f970f [roha] 			result.push(boxCells(widths,row,discord));
1a8f970f [roha] 			result.push(boxSplit(widths));
1a8f970f [roha] 			header=false
1a8f970f [roha] 		}else{
1a8f970f [roha] 			// ignore spacers
1a8f970f [roha] 			const content=row.join("").replaceAll("-","").replaceAll(" ","");
1a8f970f [roha] 			if(content.length) result.push(boxCells(widths,row,discord));
1a8f970f [roha] 		}
1a8f970f [roha] 	}
1a8f970f [roha] 	result.push(boxBottom(widths));
1a8f970f [roha] 	if(addFence) result.push("```");
1a8f970f [roha] }
