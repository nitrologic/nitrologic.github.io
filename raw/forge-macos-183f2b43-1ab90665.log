1a8f970e [roha] 
1a8f970e [roha] 						// Log for debugging (optional)
1a8f970e [roha] 						// echo('[CLAUDE] Response:', { model, choices, usage, finish_reason });
1a8f970e [roha] 
1a8f970e [roha] 						return {
