1a8f970f [roha] 		const padding=(pads>0)?" ".repeat(pads):"";
1a8f970f [roha] 		bits.push(cell+thinpad+padding);
1a8f970f [roha] 	}
1a8f970f [roha] 	for(let i=widths.length;i<cells.length;i++){
1a8f970f [roha] 		const value=cells[i];
1a8f970f [roha] 		dags.push(value);
1a8f970f [roha] 	}
1a8f970f [roha] 	return v+bits.join(v)+v+dags.join( );
