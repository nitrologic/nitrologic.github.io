1a8f970f [roha] 		for (let i=0; i < list.length; i++) {
1a8f970f [roha] 			const current=list[i];
1a8f970f [roha] 			if(last && last.role==current.role){
1a8f970f [roha] 				last.content += "\n" + current.content;
