1a8f970e [roha] 	name=name.replace("Meta-Llama-","Llama");
1a8f970e [roha] 	name=name.replace("-experimental","#");
1a8f970e [roha] //	name=name.replace("-Instruct","");
1a8f970e [roha] //	name=name.replace("-instruct","");
1a8f970e [roha] 	name=name.replace("-beta","");
1a8f970e [roha] 	name=name.replace("-preview","");
1a8f970e [roha] 	name=name.replace("-next","");
1a8f970e [roha] // qwen3 trims
1a8f970e [roha] 	name=name.replace("-flash","");
1a8f970e [roha] //	name=name.replace("-realtime","");
1a8f970e [roha] // grok 4 trims
1a8f970e [roha] 	name=name.replace("-fast","");
1a8f970e [roha] 	name=name.replace("-non-reasoning","");
1a8f970e [roha] //	name=name.replace("-generate","");
1a8f970e [roha] 	const namebits=name.split("-");
1a8f970e [roha] 	const muts=namebits.slice(0,3);
1a8f970e [roha] 	const bit=namebits[3]||"0.0";
1a8f970e [roha] 	if ((bit.length==1)||isNaN(parseFloat(bit))) muts.push(bit);
1a8f970e [roha] 	return muts.join("-");
1a8f970e [roha] }
