1a7439dc [gemini-3.1-pro] #
1a7439dc [gemini-3.1-pro] #        // Trigger immediate watchdog reset
1a7439dc [gemini-3.1-pro] #        watchdog_reboot(0, 0, 0);
1a7439dc [gemini-3.1-pro] #    }
1a7439dc [gemini-3.1-pro] #}
1a7439dc [gemini-3.1-pro] #
1a7439dc [gemini-3.1-pro] #
1a7439dc [gemini-3.1-pro] #• 5. Typical reset button added to a Pico*
1a7439dc [gemini-3.1-pro] #To add a physical hardware reset button, wire a momentary push-button switch between the
1a7439dc [gemini-3.1-pro] #RUN pin (Physical Pin 30) and any GND pin (e.g., Physical Pin 28). Pressing it
1a7439dc [gemini-3.1-pro] #pulls the RUN pin low, instantly hardware-resetting the RP2350.
1a7439dc [gemini-3.1-pro] #
