1a8f970f [roha] 			const errorText = new TextDecoder().decode(stderr);
1a8f970f [roha] 			throw new Error(`Failed to copy to clipboard: ${errorText}`);
1a8f970f [roha] 		}
1a8f970f [roha] 		process.close();
1a8f970f [roha] 	} catch (err) {
1a8f970f [roha] 		if (err instanceof Deno.errors.NotFound) {
1a8f970f [roha] 			throw new Error(`Clipboard command '${clipCmd}' not found. Ensure it is installed.`);
1a8f970f [roha] 		}
1a8f970f [roha] 		throw err;
1a8f970f [roha] 	}
1a8f970f [roha] }
