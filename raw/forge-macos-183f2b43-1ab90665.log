1a8f970e [roha] async function saveGeminiSpeech(audio: Uint8Array, mimeType:string, metaData:string[]): Promise<string> {
1a8f970e [roha] 	// expecting audio/L16;codec=pcm;rate=24000
1a8f970e [roha] 	const format:string = "wav";
1a8f970e [roha] 	const timestamp=Math.floor(Date.now()/1000).toString(16);
1a8f970e [roha] 	const filename=("speech-"+timestamp)+"."+format;
1a8f970e [roha] 	const filePath=resolve(forgePath,filename);
1a8f970e [roha] 	const line="saved "+filename;
1a8f970e [roha] 	rohaHistory.push({role:"system",title:"saveSpeech",content:line});
1a8f970e [roha] // Create a WAV header (44 bytes)
1a8f970e [roha] 	const header = new Uint8Array(44);
1a8f970e [roha] 	const view = new DataView(header.buffer);
1a8f970e [roha] // RIFF chunk descriptor
1a8f970e [roha] 	view.setUint32(0, 0x52494646, false); // "RIFF"
1a8f970e [roha] 	view.setUint32(4, 36 + audio.length, true); // File size - 8
1a8f970e [roha] 	view.setUint32(8, 0x57415645, false); // "WAVE"
1a8f970e [roha] // Format subchunk
1a8f970e [roha] 	view.setUint32(12, 0x666d7420, false); // "fmt "
1a8f970e [roha] 	view.setUint32(16, 16, true); // Subchunk size (16 for PCM)
1a8f970e [roha] 	view.setUint16(20, 1, true); // Audio format (1 = PCM)
1a8f970e [roha] 	view.setUint16(22, 1, true); // Channels (1 = mono)
1a8f970e [roha] 	view.setUint32(24, 24000, true); // Sample rate (16kHz)
1a8f970e [roha] 	view.setUint32(28, 24000 * 2, true); // Byte rate (sample rate * bytes per sample)
1a8f970e [roha] 	view.setUint16(32, 2, true); // Block align (channels * bytes per sample)
1a8f970e [roha] 	view.setUint16(34, 16, true); // Bits per sample (16-bit)
1a8f970e [roha] // Data subchunk
1a8f970e [roha] 	view.setUint32(36, 0x64617461, false); // "data"
1a8f970e [roha] 	view.setUint32(40, audio.length, true); // Data size
1a8f970e [roha] // Combine header and audio data
1a8f970e [roha] 	const wavBytes = new Uint8Array(header.length + audio.length);
1a8f970e [roha] 	wavBytes.set(header, 0);
1a8f970e [roha] 	wavBytes.set(audio, header.length);
1a8f970e [roha] 	try {
1a8f970e [roha] 		await Deno.writeFile(filePath, wavBytes);
1a8f970e [roha] 		echo("[SAY]", line);
1a8f970e [roha] 		return filePath;
1a8f970e [roha] 	} catch (error) {
1a8f970e [roha] 		echo("[SAY] Speech save error", error.message);
1a8f970e [roha] 		throw error; // Re-throw to handle the error upstream
1a8f970e [roha] 	}
1a8f970e [roha] }
