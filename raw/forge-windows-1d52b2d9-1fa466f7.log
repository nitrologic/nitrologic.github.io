1e53d453 [claude-haiku-4-5] #• Syntax:*
1e53d453 [claude-haiku-4-5] #
1e53d453 [claude-haiku-4-5] #wait <pol> gpio <gpio_num>              ; Wait on absolute GPIO
1e53d453 [claude-haiku-4-5] #wait <pol> pin <pin_num>                ; Wait on IN-mapped pin
1e53d454 [claude-haiku-4-5] #wait <pol> irq (prev|next) <irq_num>    ; Wait on IRQ flag
1e53d454 [claude-haiku-4-5] #wait <pol> jmppin (+<offset>)           ; Wait on JMP pin
1e53d454 [claude-haiku-4-5] #
1e53d454 [claude-haiku-4-5] #
1e53d455 [claude-haiku-4-5] #• Polarity:* 0 = wait for low, 1 = wait for high.
1e53d455 [claude-haiku-4-5] #
1e53d455 [claude-haiku-4-5] #• Special IRQ behavior:*
1e53d455 [claude-haiku-4-5] #- `wait 1 irq 0` clears flag 0 when condition met
