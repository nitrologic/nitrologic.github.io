1d53d39c [deepseek-v4] #    sloppyListen = !sloppyListen; // initial toggle doesn't matter
1d53d39c [deepseek-v4] #}
1d53d39c [deepseek-v4] #
1d53d39c [deepseek-v4] #
1d53d39d [deepseek-v4] #But you also need to handle both connections without toggling. Instead of alternation, keep
1d53d39d [deepseek-v4] #both listener promises alive and handle each new connection independently.
