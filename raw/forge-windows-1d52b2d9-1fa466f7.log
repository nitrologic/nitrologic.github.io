1ddf09e7 [deepseek-v4] #• WST timing calculations*
1ddf09e7 [deepseek-v4] #
1ddf09e8 [deepseek-v4] #╭────────────────────────────────────────┬────────────────────────────────────╮
1ddf09e8 [deepseek-v4] #│  Section                               │  Cycles                            │
1ddf09e8 [deepseek-v4] #├────────────────────────────────────────┼────────────────────────────────────┤
1ddf09e8 [deepseek-v4] #│  Hsync (813) + Back porch (957)        │  1770                              │
1ddf09e9 [deepseek-v4] #│  WST delay loop (28 loops × 33 = 957)  │  957                               │
1ddf09e9 [deepseek-v4] #│  **Start of first WST bit**            │  **2727 cycles from line start**   │
1ddf09e9 [deepseek-v4] #│  WST 384 bits × 23 cycles/bit          │  8832                              │
1ddf09e9 [deepseek-v4] #│  **End of WST transmission**           │  **11559 cycles from line start**  │
1ddf09ea [deepseek-v4] #│  Intended line length                  │  10656 cycles                      │
1ddf09ea [deepseek-v4] #╰────────────────────────────────────────┴────────────────────────────────────╯
1ddf09ea [deepseek-v4] #
1ddf09ea [deepseek-v4] #Clearly the WST payload overflows the line. Even the active video window (currently 9504 cycles due
1ddf09eb [deepseek-v4] #to 11‑cycle pixels) ends at 1770 + 9504 = 11274 cycles, so WST ends at 11559 — outside the front
1ddf09eb [deepseek-v4] #porch, corrupting the next line.
