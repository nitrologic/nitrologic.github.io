1e3ebc10 [deepseek-v4] #╰────────────────┴────────────────┴──────────────────────────────────────────────────────────────┴────────────────────────────────────────────┴───────────────────────────────╯
1e3ebc10 [deepseek-v4] #
1e3ebc10 [deepseek-v4] #Comparison with equal resistors (150 Ω each)
