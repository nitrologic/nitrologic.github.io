1e3f12a9 [deepseek-v4] #╭───────────────────────┬───────────────┬───────────────┬─────────────────────────────────╮
1e3f12aa [deepseek-v4] #│  Video region         │  Luma pin     │  Grey pin     │  Effect on output               │
1e3f12aa [deepseek-v4] #├───────────────────────┼───────────────┼───────────────┼─────────────────────────────────┤
