1e53d461 [claude-haiku-4-5] #push block                ; Stall if RX FIFO full
1e53d462 [claude-haiku-4-5] #push noblock              ; Discard if RX FIFO full
1e53d462 [claude-haiku-4-5] #push iffull               ; Only push if ISR count ≥ threshold
1e53d462 [claude-haiku-4-5] #push iffull block
1e53d462 [claude-haiku-4-5] #
1e53d463 [claude-haiku-4-5] #
