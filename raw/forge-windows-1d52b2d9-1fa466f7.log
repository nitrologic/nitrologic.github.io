1e3f12aa [deepseek-v4] #│                       │  High‑Z       │  Output high  │  Slightly brighter (~1.55 V)    │
1e3f12ab [deepseek-v4] #│                       │  Output high  │  Output high  │  Maximum bright (~2.15 V)       │
1e3f12ab [deepseek-v4] #╰───────────────────────┴───────────────┴───────────────┴─────────────────────────────────╯
