1e0025ed [gemini-3.1-pro] #
1e0025ed [gemini-3.1-pro] #.program twobit
1e0025ed [gemini-3.1-pro] #	out	pins, 2
1e0025ed [gemini-3.1-pro] #	in	pins, 2     ; Shift 2 bits from the pins into the ISR
1e0025ee [gemini-3.1-pro] #	push	block       ; Push the ISR into the RX FIFO
1e0025ee [gemini-3.1-pro] #
