1eebb6f5 [kimi-k2.6] # ꔀ nitrologic Relay 1.8.7 ⛲  kimi-k2.6 🜁 🪠 🧊 $0.096 302.5KB 172.67s
1eebb6f5 [kimi-k2.6] #With the existing `i2s.pio` frame format (3125 state-machine cycles per stereo sample) you have two
1eebb6f5 [kimi-k2.6] #choices:
1eebb6f5 [kimi-k2.6] #
1eebb6f6 [kimi-k2.6] #• 1. Keep the program as-is and use the fractional clock divider*
1eebb6f6 [kimi-k2.6] #
1eebb6f6 [kimi-k2.6] #Target PIO clock = 44,100 × 3125 = 137.8125 MHz
1eebb6f6 [kimi-k2.6] #
1eebb6f7 [kimi-k2.6] #Clock divisor = 166.5 / 137.8125 = 1.208163…
1eebb6f7 [kimi-k2.6] #
1eebb6f7 [kimi-k2.6] #In the RP2350 16.8 fixed-point `CLKDIV` register:
1eebb6f7 [kimi-k2.6] #
1eebb6f8 [kimi-k2.6] #╭───────┬────────┬──────────────────┬─────────────────────────────┬──────────────┬───────────╮
1eebb6f8 [kimi-k2.6] #│  INT  │  FRAC  │  Register value  │  Actual rate                │  Error       │ undefined │
1eebb6f8 [kimi-k2.6] #├───────┼────────┼──────────────────┼─────────────────────────────┼──────────────┼───────────┤
1eebb6f9 [kimi-k2.6] #│  1    │  53    │  `(1 << 16) \    │  (53 << 8)` = `0x00013500`  │  ~44,141 Hz  │  +0.09 %  │
1eebb6f9 [kimi-k2.6] #│  1    │  54    │  `(1 << 16) \    │  (54 << 8)` = `0x00013600`  │  ~43,999 Hz  │  −0.23 %  │
1eebb6f9 [kimi-k2.6] #╰───────┴────────┴──────────────────┴─────────────────────────────┴──────────────┴───────────╯
1eebb6f9 [kimi-k2.6] #
1eebb6fa [kimi-k2.6] #So `0x00013500` (1 + 53/256) is the closer match.
1eebb6fa [kimi-k2.6] #
1eebb6fa [kimi-k2.6] #• 2. Run the SM at full system speed (divisor 1.0) and retime the program*
1eebb6fa [kimi-k2.6] #
1eebb6fb [kimi-k2.6] #166.5 MHz / 44.1 kHz = 3775.51 cycles per sample
1eebb6fb [kimi-k2.6] #
1eebb6fb [kimi-k2.6] #If you stretch the program to exactly 3775 cycles per left+right frame you get:
1eebb6fb [kimi-k2.6] #
1eebb6fb [kimi-k2.6] #166,500,000 / 3775 = 44,099.34 Hz
1eebb6fc [kimi-k2.6] #
1eebb6fc [kimi-k2.6] #That is within 0.7 Hz (0.0016 %) of true 44.1 kHz and avoids any fractional-divider jitter. You
1eebb6fc [kimi-k2.6] #would need to add 650 cycles of delay to the existing 3125-cycle program (for example, by
1eebb6fd [kimi-k2.6] #padding the `[n]` delay fields in the `left16` / `right16` loops).
1eebb6fd [kimi-k2.6] #
1eebb6fd [kimi-k2.6] #If you want the exact register write for option 1 in the SDK style:
1eebb6fd [kimi-k2.6] #
1eebb6fe [kimi-k2.6] #
1eebb6fe [kimi-k2.6] #pio->sm[sm].clkdiv = (1u << 16) | (53u << 8);   // 44.141 kHz
1eebb6fe [kimi-k2.6] #
1eebb6fe [kimi-k2.6] #
