1e53d48e [claude-haiku-4-5] #11.5.3 FIFO Joining
1e53d48e [claude-haiku-4-5] #
1e53d48e [claude-haiku-4-5] #Merge 4+4 FIFOs into 8-entry single direction.
1e53d48f [claude-haiku-4-5] #
1e53d48f [claude-haiku-4-5] #╭──────────────────┬───────────┬─────────────────────┬────────────────────────────────────╮
1e53d48f [claude-haiku-4-5] #│  Mode            │  TX Size  │  RX Size            │  Use Case                          │
1e53d48f [claude-haiku-4-5] #├──────────────────┼───────────┼─────────────────────┼────────────────────────────────────┤
1e53d48f [claude-haiku-4-5] #│  txrx (default)  │  4        │  4                  │  Bidirectional                     │
1e53d490 [claude-haiku-4-5] #│  tx              │  8        │  0                  │  Output-heavy (DPI, SPI master)    │
1e53d490 [claude-haiku-4-5] #│  rx              │  0        │  8                  │  Input-heavy (SPI slave, UART RX)  │
1e53d490 [claude-haiku-4-5] #│  txget           │  4        │  4 (indexed read)   │  Lookup tables                     │
1e53d490 [claude-haiku-4-5] #│  txput           │  4        │  4 (indexed write)  │  Status registers                  │
1e53d491 [claude-haiku-4-5] #│  putget          │  0        │  8 (indexed r/w)    │  Scratchpad                        │
1e53d491 [claude-haiku-4-5] #╰──────────────────┴───────────┴─────────────────────┴────────────────────────────────────╯
1e53d491 [claude-haiku-4-5] #
1e53d491 [claude-haiku-4-5] #• Caution:* Changing FJOIN discards in-flight data.
1e53d492 [claude-haiku-4-5] #
