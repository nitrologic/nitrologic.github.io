1ed282a7 [nitro@ryzen5] int SPDIFStateMachine=0;// spdif reads digital audio on GP18 using the hilo32 pio machineconst int audioWordCount = 8192;alignas(1024) uint32_t audioWordBuffer[audioWordCount];int spdif_dma_chan;void spdif_dma_init(PIO pio,int sm) {	spdif_dma_chan = dma_claim_unused_channel(true);	dma_channel_config c = dma_channel_get_default_config(spdif_dma_chan);	channel_config_set_transfer_data_size(&c, DMA_SIZE_32);	channel_config_set_read_increment(&c, false);	channel_config_set_write_increment(&c, true);	channel_config_set_dreq(&c, pio_get_dreq(pio, sm, false));	dma_channel_configure(spdif_dma_chan,&c,audioWordBuffer,&pio->rxf[sm],audioWordCount,false);}bool spdif_init(PIO pio,int sm){	pio_gpio_init(pio,SPDIF_PIN);	const pio_program_t *program12=&hilo32_program;	if (!pio_can_add_program(pio, program12)) return false;	uint offset12 = pio_add_program(pio, program12);	pio_sm_config config=hilo32_program_get_default_config(offset12);	sm_config_set_in_pins(&config, SPDIF_PIN);	sm_config_set_jmp_pin(&config, SPDIF_PIN);	spdif_dma_init(pio,sm);	int pioStatus=pio_sm_init(pio, sm, offset12, &config);	return true;}
