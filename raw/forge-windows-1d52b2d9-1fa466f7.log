1e53d470 [claude-haiku-4-5] #- `::` – Bit reverse
1e53d471 [claude-haiku-4-5] #
1e53d471 [claude-haiku-4-5] #• Destinations:*
1e53d471 [claude-haiku-4-5] #- `pins`, `x`, `y` – As above
1e53d471 [claude-haiku-4-5] #- `pindirs` – Bulk direction control (RP2350 only)
1e53d472 [claude-haiku-4-5] #- `exec` – Execute as instruction
1e53d472 [claude-haiku-4-5] #- `pc` – Unconditional jump
1e53d472 [claude-haiku-4-5] #- `isr`, `osr` – Shift registers (clears shift counters)
1e53d472 [claude-haiku-4-5] #
1e53d473 [claude-haiku-4-5] #• Sources:*
1e53d473 [claude-haiku-4-5] #- `pins` – IN-mapped inputs (masked to IN_COUNT bits)
1e53d473 [claude-haiku-4-5] #- `x`, `y`, `null` – Registers / zeroes
1e53d473 [claude-haiku-4-5] #- `status` – All 1s or all 0s (configurable by EXECCTRLSTATUSSEL)
1e53d474 [claude-haiku-4-5] #- `isr`, `osr` – Shift registers
1e53d474 [claude-haiku-4-5] #
1e53d474 [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1e53d474 [claude-haiku-4-5] #
1e53d475 [claude-haiku-4-5] #11.4.11 IRQ
1e53d475 [claude-haiku-4-5] #
1e53d475 [claude-haiku-4-5] #• Syntax:*
1e53d475 [claude-haiku-4-5] #
1e53d476 [claude-haiku-4-5] #irq (prev|next) set <n> (rel)     ; Set flag n
1e53d476 [claude-haiku-4-5] #irq (prev|next) clear <n> (rel)   ; Clear flag n
1e53d476 [claude-haiku-4-5] #irq (prev|next) wait <n> (rel)    ; Set and wait for clear
1e53d476 [claude-haiku-4-5] #irq (prev|next) nowait <n> (rel)  ; Alias for 'set'
1e53d477 [claude-haiku-4-5] #
1e53d477 [claude-haiku-4-5] #
1e53d477 [claude-haiku-4-5] #• Cross-PIO modes:*
1e53d477 [claude-haiku-4-5] #- (no prefix) – This PIO block
1e53d478 [claude-haiku-4-5] #- `prev` – Next lower-numbered PIO (wraps)
1e53d478 [claude-haiku-4-5] #- `next` – Next higher-numbered PIO (wraps)
1e53d478 [claude-haiku-4-5] #- `rel` – Add SM number to flag index (mod 4 on 2 LSBs)
1e53d478 [claude-haiku-4-5] #
1e53d479 [claude-haiku-4-5] #• Example (inter-SM sync):*
1e53d479 [claude-haiku-4-5] #
1e53d479 [claude-haiku-4-5] #; SM0
1e53d479 [claude-haiku-4-5] #irq set 0 rel    ; Set flag (0 + 0) = flag 0
1e53d47a [claude-haiku-4-5] #wait 1 irq 0 rel ; Wait on flag 0
1e53d47a [claude-haiku-4-5] #
1e53d47a [claude-haiku-4-5] #; SM1
1e53d47a [claude-haiku-4-5] #irq set 0 rel    ; Set flag (0 + 1) = flag 1
1e53d47b [claude-haiku-4-5] #wait 1 irq 0 rel ; Wait on flag 1
1e53d47b [claude-haiku-4-5] #
1e53d47b [claude-haiku-4-5] #
1e53d47b [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1e53d47c [claude-haiku-4-5] #
1e53d47c [claude-haiku-4-5] #11.4.12 SET
1e53d47c [claude-haiku-4-5] #
1e53d47c [claude-haiku-4-5] #• Syntax:*
1e53d47d [claude-haiku-4-5] #
1e53d47d [claude-haiku-4-5] #set <destination>, <value>
1e53d47d [claude-haiku-4-5] #
1e53d47d [claude-haiku-4-5] #
1e53d47e [claude-haiku-4-5] #• Destinations:*
1e53d47e [claude-haiku-4-5] #- `pins` – Drive SET pins to value (0-31)
1e53d47e [claude-haiku-4-5] #- `x`, `y` – Load into scratch registers (5 LSBs, rest cleared)
1e53d47e [claude-haiku-4-5] #- `pindirs` – Set pin directions
1e53d47e [claude-haiku-4-5] #
1e53d47f [claude-haiku-4-5] #• Typical use:* Loop counters, chip select, clock edges.
1e53d47f [claude-haiku-4-5] #
1e53d47f [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1e53d47f [claude-haiku-4-5] #
1e53d480 [claude-haiku-4-5] #11.5 Functional Details
1e53d480 [claude-haiku-4-5] #
1e53d480 [claude-haiku-4-5] #11.5.1 Side-Set
1e53d480 [claude-haiku-4-5] #
1e53d481 [claude-haiku-4-5] #Simultaneously changes GPIOs while executing main instruction.
1e53d481 [claude-haiku-4-5] #
1e53d481 [claude-haiku-4-5] #• Benefits:*
1e53d481 [claude-haiku-4-5] #- Precise timing (SPI clock + data edges)
1e53d482 [claude-haiku-4-5] #- Compact code (no extra SET instruction)
1e53d482 [claude-haiku-4-5] #- Independent pin mapping from OUT/SET
1e53d482 [claude-haiku-4-5] #
1e53d482 [claude-haiku-4-5] #• Configuration:*
1e53d483 [claude-haiku-4-5] #- Number of pins: `PINCTRLSIDESETCOUNT` (0-5)
1e53d483 [claude-haiku-4-5] #- Enable bit optional: `EXECCTRLSIDEEN`
1e53d483 [claude-haiku-4-5] #- Pin direction: `EXECCTRLSIDEPINDIR` (pins or pindirs)
1e53d483 [claude-haiku-4-5] #- Base pin: `PINCTRLSIDESETBASE`
1e53d484 [claude-haiku-4-5] #
1e53d484 [claude-haiku-4-5] #• Example: Fast SPI*
1e53d484 [claude-haiku-4-5] #
1e53d484 [claude-haiku-4-5] #.program spi_tx_fast
1e53d485 [claude-haiku-4-5] #.side_set 1
1e53d485 [claude-haiku-4-5] #
1e53d485 [claude-haiku-4-5] #loop:
1e53d485 [claude-haiku-4-5] #    out pins, 1 side 0    ; Output data, clock low
1e53d486 [claude-haiku-4-5] #    jmp loop side 1       ; Jump, clock high
1e53d486 [claude-haiku-4-5] #
1e53d486 [claude-haiku-4-5] #
1e53d486 [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1e53d487 [claude-haiku-4-5] #
1e53d487 [claude-haiku-4-5] #11.5.2 Program Wrapping
1e53d487 [claude-haiku-4-5] #
1e53d487 [claude-haiku-4-5] #Eliminates JMP overhead via hardware loop.
1e53d488 [claude-haiku-4-5] #
1e53d488 [claude-haiku-4-5] #• Syntax:*
1e53d488 [claude-haiku-4-5] #
1e53d488 [claude-haiku-4-5] #.program squarewave_wrap
1e53d489 [claude-haiku-4-5] #set pindirs, 1
1e53d489 [claude-haiku-4-5] #.wrap_target
1e53d489 [claude-haiku-4-5] #    set pins, 1 [1]
1e53d489 [claude-haiku-4-5] #    set pins, 0 [1]
1e53d48a [claude-haiku-4-5] #.wrap
1e53d48a [claude-haiku-4-5] #
1e53d48a [claude-haiku-4-5] #
1e53d48a [claude-haiku-4-5] #• How it works:*
1e53d48b [claude-haiku-4-5] #1. If PC matches WRAPTOP, jump to WRAPBOTTOM
1e53d48b [claude-haiku-4-5] #2. Else increment PC (wrap at 31)
1e53d48b [claude-haiku-4-5] #3. JMP still takes precedence
1e53d48b [claude-haiku-4-5] #
1e53d48c [claude-haiku-4-5] #• Generated config:*
1e53d48c [claude-haiku-4-5] #
1e53d48c [claude-haiku-4-5] ##define squarewave_wrap_wrap_target 1
1e53d48c [claude-haiku-4-5] ##define squarewave_wrap_wrap 2
1e53d48d [claude-haiku-4-5] #sm_config_set_wrap(&c, offset + wrap_target, offset + wrap);
1e53d48d [claude-haiku-4-5] #
1e53d48d [claude-haiku-4-5] #
1e53d48d [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
