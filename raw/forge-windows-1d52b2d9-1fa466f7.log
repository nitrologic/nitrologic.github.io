1ed1d87f [gemini-3.1-lite] #.side_set 0
1ed1d87f [gemini-3.1-lite] #
1ed1d880 [gemini-3.1-lite] #; We sample at a high frequency to detect the BMC transitions.
1ed1d880 [gemini-3.1-lite] #; The goal is to detect the edge, then count cycles until the next edge.
1ed1d880 [gemini-3.1-lite] #
1ed1d880 [gemini-3.1-lite] #public entry:
1ed1d881 [gemini-3.1-lite] #    wait 1 pin 0        ; Wait for line to go high (start of bit/transition)
1ed1d881 [gemini-3.1-lite] #    wait 0 pin 0        ; Wait for line to go low (transition)
1ed1d881 [gemini-3.1-lite] #    set x, 0            ; Reset counter
1ed1d881 [gemini-3.1-lite] #
1ed1d882 [gemini-3.1-lite] #count_loop:
1ed1d882 [gemini-3.1-lite] #    jmp pin, count_loop ; If pin is still high, keep counting
1ed1d882 [gemini-3.1-lite] #    jmp bit_detected    ; If pin goes low, we found the mid-bit transition
1ed1d882 [gemini-3.1-lite] #
1ed1d883 [gemini-3.1-lite] #count_loop_inc:
1ed1d883 [gemini-3.1-lite] #    jmp x--, count_loop ; Increment our cycle counter to measure duration
1ed1d883 [gemini-3.1-lite] #
1ed1d883 [gemini-3.1-lite] #bit_detected:
1ed1d884 [gemini-3.1-lite] #    in x, 8             ; Push the duration count to the RX FIFO
1ed1d884 [gemini-3.1-lite] #    jmp entry
1ed1d884 [gemini-3.1-lite] #
1ed1d884 [gemini-3.1-lite] #% c-sdk {
1ed1d885 [gemini-3.1-lite] #static inline void spdif_program_init(PIO pio, uint sm, uint offset, uint pin) {
1ed1d885 [gemini-3.1-lite] #    pio_sm_config c = spdif_program_get_default_config(offset);
1ed1d885 [gemini-3.1-lite] #
1ed1d886 [gemini-3.1-lite] #    // Set the pin as input
1ed1d886 [gemini-3.1-lite] #    pio_gpio_init(pio, pin);
1ed1d886 [gemini-3.1-lite] #    sm_config_set_in_pins(&c, pin);
1ed1d886 [gemini-3.1-lite] #
1ed1d887 [gemini-3.1-lite] #    // Set pin as JMP pin for the state machine
1ed1d887 [gemini-3.1-lite] #    sm_config_set_jmp_pin(&c, pin);
1ed1d887 [gemini-3.1-lite] #
1ed1d887 [gemini-3.1-lite] #    pio_sm_init(pio, sm, offset, &c);
1ed1d888 [gemini-3.1-lite] #    pio_sm_set_enabled(pio, sm, true);
1ed1d888 [gemini-3.1-lite] #}
1ed1d888 [gemini-3.1-lite] #%}
1ed1d888 [gemini-3.1-lite] #
1ed1d889 [gemini-3.1-lite] #
1ed1d889 [gemini-3.1-lite] #How this logic works:
1ed1d889 [gemini-3.1-lite] #1.  Transition Detection: Instead of trying to sample at exactly the bit center, this code
1ed1d889 [gemini-3.1-lite] #measures the time between transitions.
1ed1d88a [gemini-3.1-lite] #2.  BMC Logic:
1ed1d88a [gemini-3.1-lite] #    *   A transition at the boundary is guaranteed.
1ed1d88a [gemini-3.1-lite] #    *   A transition in the middle indicates a `1`.
1ed1d88a [gemini-3.1-lite] #    *   By measuring the time between the boundary transition and the next transition, the PIO
1ed1d88b [gemini-3.1-lite] #captures the "delta" time.
1ed1d88b [gemini-3.1-lite] #3.  The "Middle Man" (FIFO): The `in x, 8` instruction sends the measured cycle count to
1ed1d88b [gemini-3.1-lite] #the RX FIFO.
1ed1d88b [gemini-3.1-lite] #4.  CPU Processing: Your C code on the RP2350 reads these values from the FIFO. If the
1ed1d88c [gemini-3.1-lite] #value is "small" (approx. 0.5 bit period), you know a `1` occurred. If the value is "large"
1ed1d88c [gemini-3.1-lite] #(approx. 1 bit period), you know a `0` occurred.
