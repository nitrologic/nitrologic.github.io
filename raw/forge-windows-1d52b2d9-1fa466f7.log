1dac4d1b [deepseek-v4] #To signal between state machines (SMs) within the same PIO block, you use the internal IRQ flags
1dac4d1b [deepseek-v4] #(0–7). Each SM can set, clear, or wait on these flags using the `irq` and `wait` instructions.
1dac4d1c [deepseek-v4] #
1dac4d1c [deepseek-v4] #• Key instructions:*
1dac4d1c [deepseek-v4] #
1dac4d1c [deepseek-v4] #- `irq set <n>` – set IRQ flag `n` (0–7).
1dac4d1d [deepseek-v4] #- `irq clear <n>` – clear IRQ flag `n`.
1dac4d1d [deepseek-v4] #- `irq wait <n>` – wait until flag `n` is cleared by another SM or the system (rarely used for
1dac4d1d [deepseek-v4] #inter-SM signalling).
1dac4d1d [deepseek-v4] #- `wait 1 irq <n>` – wait for IRQ flag `n` to become set.
1dac4d1e [deepseek-v4] #- `wait 0 irq <n>` – wait for IRQ flag `n` to become cleared.
1dac4d1e [deepseek-v4] #
1dac4d1e [deepseek-v4] #• Within the same PIO block:*
1dac4d1e [deepseek-v4] #All SMs see the same IRQ flags. IRQ0–3 can also trigger a system interrupt, but you can use any
1dac4d1f [deepseek-v4] #flag (0–7) for SM-to-SM communication. IRQ4–7 are also visible to the other PIO block (if
1dac4d1f [deepseek-v4] #present), so for intra-block communication you may prefer IRQ0–3 to avoid confusion.
1dac4d1f [deepseek-v4] #
1dac4d1f [deepseek-v4] #• Simple example (PIO assembly, pioasm syntax):*
1dac4d20 [deepseek-v4] #
1dac4d20 [deepseek-v4] #
1dac4d20 [deepseek-v4] #.program producer
1dac4d20 [deepseek-v4] #    ; Continuously set IRQ0 after each sample
1dac4d21 [deepseek-v4] #loop:
1dac4d21 [deepseek-v4] #    out y, 32         ; read 32-bit sample
1dac4d21 [deepseek-v4] #    mov pins, y       ; output to pins
1dac4d21 [deepseek-v4] #    irq set 0         ; signal consumer SM
1dac4d22 [deepseek-v4] #    jmp loop
1dac4d22 [deepseek-v4] #
1dac4d22 [deepseek-v4] #.program consumer
1dac4d22 [deepseek-v4] #    ; Wait for IRQ0, then read
1dac4d23 [deepseek-v4] #loop:
1dac4d23 [deepseek-v4] #    wait 1 irq 0      ; block until IRQ0 is set
1dac4d23 [deepseek-v4] #    irq clear 0       ; clear flag (optional, for next cycle)
1dac4d24 [deepseek-v4] #    in pins, 32       ; capture input
1dac4d24 [deepseek-v4] #    push              ; push to RX FIFO
1dac4d24 [deepseek-v4] #    jmp loop
1dac4d24 [deepseek-v4] #
1dac4d25 [deepseek-v4] #
1dac4d25 [deepseek-v4] #In this scenario, SM0 (producer) sets IRQ0 after writing a sample. SM1 (consumer) waits for that
1dac4d25 [deepseek-v4] #flag, clears it, then processes the data. The `irq clear` is necessary if you want the flag to be
1dac4d25 [deepseek-v4] #reused for the next sample; otherwise, the wait would never block again because the flag remains
1dac4d26 [deepseek-v4] #set.
1dac4d26 [deepseek-v4] #
1dac4d26 [deepseek-v4] #• C SDK usage (if you prefer):*
1dac4d26 [deepseek-v4] #
1dac4d27 [deepseek-v4] #When adding the program with `pioaddprogram()` and starting the state machines, you don't
1dac4d27 [deepseek-v4] #need any special setup – the IRQ flags are automatically available.
