1e53d4a6 [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1e53d4a6 [claude-haiku-4-5] #
1e53d4a6 [claude-haiku-4-5] #11.5.7 Forced & EXEC'd Instructions
1e53d4a6 [claude-haiku-4-5] #
1e53d4a7 [claude-haiku-4-5] #Execute instructions from sources other than instruction memory:
1e53d4a7 [claude-haiku-4-5] #
1e53d4a7 [claude-haiku-4-5] #╭──────────────────────────┬─────────────────────┬────────────────────────────────────────────────────────╮
1e53d4a7 [claude-haiku-4-5] #│  Source                  │  Syntax             │  Behavior                                              │
1e53d4a8 [claude-haiku-4-5] #├──────────────────────────┼─────────────────────┼────────────────────────────────────────────────────────┤
