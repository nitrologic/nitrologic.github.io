1db03b46 [deepseek-v4] #I see you’ve updated the clock divider to `2.3471f` (producing ~70.94 MHz, i.e. 16× f_sc), which is
1db03b46 [deepseek-v4] #correct. However, the image remains monochrome because several other critical issues from the
1db03b46 [deepseek-v4] #original design have not been addressed. Below is a checklist of the remaining problems that must
1db03b46 [deepseek-v4] #be fixed to get a correct PAL colour burst and eventually a red picture.
1db03b47 [deepseek-v4] #
1db03b47 [deepseek-v4] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1db03b47 [deepseek-v4] #
1db03b47 [deepseek-v4] #1. PIO loop timing (still 3 cycles per phase)
1db03b48 [deepseek-v4] #Your `chroma.pio` file (not shown in the latest snippet) likely still has the original 3‑cycle
1db03b48 [deepseek-v4] #loop:
1db03b48 [deepseek-v4] #
1db03b48 [deepseek-v4] #loop:
1db03b49 [deepseek-v4] #	out	pins, 2 [1]      ; 1+1 = 2 cycles
1db03b49 [deepseek-v4] #	jmp	x-- loop         ; 1 cycle = total 3 cycles
1db03b49 [deepseek-v4] #
1db03b49 [deepseek-v4] #To obtain exactly 4 cycles per 90° phase (required for a 4.43361875 MHz subcarrier when
1db03b4a [deepseek-v4] #running at 16× f_sc), you must insert one extra delay:
1db03b4a [deepseek-v4] #
1db03b4a [deepseek-v4] #loop:
1db03b4a [deepseek-v4] #	out	pins, 2 [2]      ; 1+2 = 3 cycles
1db03b4b [deepseek-v4] #	jmp	x-- loop         ; 1 cycle = total 4 cycles
1db03b4b [deepseek-v4] #
1db03b4b [deepseek-v4] #
1db03b4b [deepseek-v4] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1db03b4c [deepseek-v4] #
1db03b4c [deepseek-v4] #2. Burst hex packing is inverted
1db03b4c [deepseek-v4] #`burst = 0x23102310` produces the wrong 2‑bit levels on the DAC pins.
1db03b4c [deepseek-v4] #`out pins, 2` shifts bits LSB first – the two‑bit pairs are taken from the lowest two bits
1db03b4d [deepseek-v4] #of the word first.
1db03b4d [deepseek-v4] #For the PAL colour burst you need the sequence `(0, 2, 3, 1)` for the even field and `(2, 3, 1, 0)`
1db03b4d [deepseek-v4] #for the odd field (swapped by 90°).
1db03b4e [deepseek-v4] #In binary:
1db03b4e [deepseek-v4] #- `0` → `00`
1db03b4e [deepseek-v4] #- `2` → `10`
1db03b4e [deepseek-v4] #- `3` → `11`
1db03b4f [deepseek-v4] #- `1` → `01`
