1dbd9413 [kimi-k2.6] #pio_sm_set_consecutive_pindirs(pio, sm, CHROMA100_PIN, 2, true);
1dbd9413 [kimi-k2.6] #
1dbd9413 [kimi-k2.6] #
1dbd9413 [kimi-k2.6] #╭──────────────────────────────────────────────────┬───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╮
1dbd9414 [kimi-k2.6] #│  Call                                            │  Why it is needed                                                                                                                     │
1dbd9414 [kimi-k2.6] #├──────────────────────────────────────────────────┼───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┤
1dbd9414 [kimi-k2.6] #│  `pio_gpio_init(pio, CHROMA100_PIN)`             │  Connects **GP20** to the PIO peripheral instead of leaving it under CPU/SIO control.                                                 │
