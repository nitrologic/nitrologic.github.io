1e53d44e [claude-haiku-4-5] #11.4.2 JMP
1e53d44e [claude-haiku-4-5] #
1e53d44e [claude-haiku-4-5] #• Syntax:*
1e53d44f [claude-haiku-4-5] #
1e53d44f [claude-haiku-4-5] #jmp <target>              ; Always jump
1e53d44f [claude-haiku-4-5] #jmp !x <target>           ; Jump if X == 0
1e53d44f [claude-haiku-4-5] #jmp x-- <target>          ; Jump if X != 0, then decrement
1e53d450 [claude-haiku-4-5] #jmp !y <target>           ; Jump if Y == 0
1e53d450 [claude-haiku-4-5] #jmp y-- <target>          ; Jump if Y != 0, then decrement
1e53d450 [claude-haiku-4-5] #jmp x!=y <target>         ; Jump if X != Y
1e53d450 [claude-haiku-4-5] #jmp pin <target>          ; Jump on EXECCTRL_JMP_PIN
1e53d451 [claude-haiku-4-5] #jmp !osre <target>        ; Jump if OSR not empty
1e53d451 [claude-haiku-4-5] #
1e53d451 [claude-haiku-4-5] #
1e53d451 [claude-haiku-4-5] #• Delays apply regardless* of condition outcome.
