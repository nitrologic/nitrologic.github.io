1e962918 [kimi-k2.6] #│  Location           │  Before                          │  Now                      │
1e962919 [kimi-k2.6] #├─────────────────────┼──────────────────────────────────┼───────────────────────────┤
1e962919 [kimi-k2.6] #│  IRQ flag test      │  `out y, 1`                      │  `out y, 2`               │
1e962919 [kimi-k2.6] #│  Cross-PIO trigger  │  `; irq next set 6` (commented)  │  `irq next set 6` (live)  │
1e962919 [kimi-k2.6] #│  Pixel data         │  `set pins, 4`                   │  `out pins, 1`            │
