1eab6cc9 [gemini-3.1-lite] #    sm_config_set_jmp_pin(&c, pin);
1eab6cc9 [gemini-3.1-lite] #
1eab6cca [gemini-3.1-lite] #    // 3. Initialize and start
1eab6cca [gemini-3.1-lite] #    pio_sm_init(pio, sm, offset, &c);
1eab6cca [gemini-3.1-lite] #    pio_sm_set_enabled(pio, sm, true);
