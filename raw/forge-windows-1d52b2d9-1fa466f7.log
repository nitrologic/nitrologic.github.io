1f3e7dde [kimi-k2.6] # ꔀ nitrologic Relay 1.8.7 ⛲  kimi-k2.6 🜁 🪠 🧊 $0.027 3.867KB 105.96s
1f3e7dde [kimi-k2.6] #For paddles you still wire DB9 pin 7 straight to your VCC rail—no series resistor there.
1f3e7dde [kimi-k2.6] #
1f3e7ddf [kimi-k2.6] #The resistor you are thinking of belongs on the paddle signal lines (DB9 pins 5 and 9), not
1f3e7ddf [kimi-k2.6] #on the power pin.
1f3e7ddf [kimi-k2.6] #
1f3e7ddf [kimi-k2.6] #Simple RC reading circuit (the usual way)
1f3e7de0 [kimi-k2.6] #
1f3e7de0 [kimi-k2.6] #╭───────────┬───────────────────┬────────────────────────────────────────╮
1f3e7de0 [kimi-k2.6] #│  DB9 pin  │  Function         │  Connection                            │
1f3e7de0 [kimi-k2.6] #├───────────┼───────────────────┼────────────────────────────────────────┤
1f3e7de1 [kimi-k2.6] #│  7        │  +5 V (or 3.3 V)  │  Direct to your regulated supply rail  │
1f3e7de1 [kimi-k2.6] #│  8        │  GND              │  Direct to MCU ground                  │
1f3e7de1 [kimi-k2.6] #│  5        │  Paddle A / X     │  Series resistor → MCU GPIO            │
1f3e7de2 [kimi-k2.6] #│  9        │  Paddle B / Y     │  Series resistor → MCU GPIO            │
1f3e7de2 [kimi-k2.6] #╰───────────┴───────────────────┴────────────────────────────────────────╯
1f3e7de2 [kimi-k2.6] #
1f3e7de2 [kimi-k2.6] #Add a capacitor (10–100 nF, e.g. 47 nF) from each of those GPIOs to ground.
1f3e7de3 [kimi-k2.6] #
1f3e7de3 [kimi-k2.6] #- Series resistor: 220 Ω to 1 kΩ (470 Ω is a good default).
1f3e7de3 [kimi-k2.6] #  This protects the GPIO when you drive it low to discharge the capacitor; if the paddle knob is at
1f3e7de3 [kimi-k2.6] #minimum resistance, the resistor limits current from VCC into the pin.
