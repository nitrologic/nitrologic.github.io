1f28a116 [kimi-k2.6] #
1f28a116 [kimi-k2.6] #• Important: Because the Pico is a 3.3 V device, do not* connect this adapter to a
1f28a116 [kimi-k2.6] #powered Atari console while the Pico is plugged in. Your circuit should supply 3.3 V to DB9 pin 7
1f28a116 [kimi-k2.6] #itself.
1f28a117 [kimi-k2.6] #
1f28a117 [kimi-k2.6] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1f28a117 [kimi-k2.6] #
