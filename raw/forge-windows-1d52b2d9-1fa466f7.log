1dafdd7a [deepseek-v4] #Chroma DMA ring size
1dafdd7b [deepseek-v4] #The most significant potential issue is in `chromadmainit`:
1dafdd7b [deepseek-v4] #
1dafdd7b [deepseek-v4] #channel_config_set_ring(&c, true, 9);
1dafdd7c [deepseek-v4] #dma_channel_configure(chroma_dma_chan, &c, &pio->txf[sm], NULL, colorWords*2, false);
