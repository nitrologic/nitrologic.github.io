1e53d49b [claude-haiku-4-5] #11.5.5 Clock Dividers
1e53d49b [claude-haiku-4-5] #
1e53d49c [claude-haiku-4-5] #Scale state machine speed via fractional divider.
1e53d49c [claude-haiku-4-5] #
1e53d49c [claude-haiku-4-5] #• Range:* 1 to 65536 (16.8 fixed-point).
1e53d49c [claude-haiku-4-5] #
1e53d49d [claude-haiku-4-5] #╭───────────┬────────────────────────────────────────────╮
1e53d49d [claude-haiku-4-5] #│  Divisor  │  Effect                                    │
1e53d49d [claude-haiku-4-5] #├───────────┼────────────────────────────────────────────┤
1e53d49d [claude-haiku-4-5] #│  1.0      │  Full speed (system clock)                 │
1e53d49e [claude-haiku-4-5] #│  2.0      │  Run 1 cycle per 2 clocks                  │
1e53d49e [claude-haiku-4-5] #│  2.5      │  Run 1 cycle per 2.5 clocks (delta-sigma)  │
1e53d49e [claude-haiku-4-5] #│  65536    │  Minimum speed                             │
1e53d49e [claude-haiku-4-5] #╰───────────┴────────────────────────────────────────────╯
1e53d49f [claude-haiku-4-5] #
1e53d49f [claude-haiku-4-5] #• Usage:*
1e53d49f [claude-haiku-4-5] #
1e53d49f [claude-haiku-4-5] #sm_config_set_clkdiv(&c, 2.5f);  // 2.5x slower
1e53d4a0 [claude-haiku-4-5] #
1e53d4a0 [claude-haiku-4-5] #
1e53d4a0 [claude-haiku-4-5] #• PAL color subcarrier (RP2350 @ 166.5 MHz):*
1e53d4a0 [claude-haiku-4-5] #- Target: 4.43361875 MHz × 4 = 17.734475 MHz
1e53d4a1 [claude-haiku-4-5] #- Divisor: 166.5 / 17.734475 ≈ 9.3885
1e53d4a1 [claude-haiku-4-5] #
1e53d4a1 [claude-haiku-4-5] #━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
