1a8ac4a3 [claude-opus-4-6] #No, I2S is a master/slave protocol with no handshaking. The Pico is the master - it generates BCK
1a8ac4a4 [claude-opus-4-6] #and WSEL, the DAC just follows.
1a8ac4a4 [claude-opus-4-6] #
1a8ac4a4 [claude-opus-4-6] #The sync concern is between your FIFO feeding and the PIO clock. If the FIFO underruns, PIO stalls
1a8ac4a4 [claude-opus-4-6] #on `out` waiting for data - BCK stops, then resumes when data arrives. The PCM5102 will handle that
1a8ac4a5 [claude-opus-4-6] #gracefully, you'll just hear a glitch.
1a8ac4a5 [claude-opus-4-6] #
1a8ac4a5 [claude-opus-4-6] #The real sync question is between your video PIO and audio PIO. Both are on PIO0 sharing the same
1a8ac4a5 [claude-opus-4-6] #clock, so they'll stay in lockstep. Your main loop needs to feed both FIFOs fast enough:
1a8ac4a6 [claude-opus-4-6] #
1a8ac4a6 [claude-opus-4-6] #
1a8ac4a6 [claude-opus-4-6] #while (!ReadBootSel()) {
1a8ac4a6 [claude-opus-4-6] #    if (!pio_sm_is_tx_fifo_full(pio, VidStateMachine)) {
1a8ac4a7 [claude-opus-4-6] #        pio_sm_put(pio, VidStateMachine, frame[p++]);
1a8ac4a7 [claude-opus-4-6] #        if (p >= wordCount) p = 0;
1a8ac4a7 [claude-opus-4-6] #    }
1a8ac4a7 [claude-opus-4-6] #    if (!pio_sm_is_tx_fifo_full(pio, AudioStateMachine)) {
1a8ac4a8 [claude-opus-4-6] #        pio_sm_put(pio, AudioStateMachine, next_audio_sample());
1a8ac4a8 [claude-opus-4-6] #    }
1a8ac4a8 [claude-opus-4-6] #}
1a8ac4a8 [claude-opus-4-6] #
1a8ac4a9 [claude-opus-4-6] #
