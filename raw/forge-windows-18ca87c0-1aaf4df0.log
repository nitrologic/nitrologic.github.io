1a8af48d [claude-opus-4-6] #No, left-justified means MSB first which requires shift-left direction:
1a8af48d [claude-opus-4-6] #
1a8af48d [claude-opus-4-6] #
1a8af48d [claude-opus-4-6] #sm_config_set_out_shift(&c, false, true, 32);
1a8af48d [claude-opus-4-6] #//                       ↑ false = shift left (MSB first)
1a8af48e [claude-opus-4-6] #
1a8af48e [claude-opus-4-6] #
1a8af48e [claude-opus-4-6] #The default PIO out shift is right (LSB first). Your video PIO uses right shift because it clocks
1a8af48e [claude-opus-4-6] #pixels left-to-right from bit 0. For I2S you need the opposite - MSB of each 16-bit sample goes out
1a8af48f [claude-opus-4-6] #first.
1a8af48f [claude-opus-4-6] #
1a8af48f [claude-opus-4-6] #So the FIFO word `0x8000_4000` would output left=0x8000 then right=0x4000, MSB first for each
1a8af48f [claude-opus-4-6] #channel.
1a8af490 [claude-opus-4-6] #
